# ==============================================
# AIStudyHub Docker Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===================
# Database
# ===================
MSSQL_SA_PASSWORD=StrongPassword123!

# ===================
# JWT Authentication
# ===================
JWT_SECRET_KEY=CHANGE_THIS_TO_A_VERY_SECURE_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG

# ===================
# Admin Account
# ===================
ADMIN_EMAIL=admin@aistudyhub.local
ADMIN_PASSWORD=ChangeThisAdmin123

# ===================
# CORS - Frontend Origins
# ===================
# Local development
CORS_ORIGIN=http://localhost:5173
# Additional origins (optional)
CORS_ORIGIN_2=

# ===================
# SMTP Email (Gmail or other SMTP provider)
# ===================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com

# ===================
# Cloudinary (File upload service)
# ===================
CLOUDINARY_USER=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===================
# External Authentication (Google/GitHub OAuth)
# ===================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ===================
# AI/ML Services (Optional)
# ===================
# Ollama (Local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest

# OpenAI (Cloud LLM)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Pinecone (Vector Database)
PINECONE_INDEX=aistudyhub-docs

# ===================
# VnPay Payment Gateway (Vietnam)
# ===================
VNPAY_TMN_CODE=your-tmn-code
VNPAY_HASH_SECRET=your-hash-secret
VNPAY_BASE_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5171/api/payment/vnpay-return
